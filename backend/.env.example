# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# Frontend / CORS
CORS_ORIGIN=http://localhost:3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_actual_mysql_password
DB_NAME=salon_booking_system
DB_CONNECTION_LIMIT=10

# JWT (used by the IAM phase)
JWT_SECRET=replace-with-a-local-development-secret
JWT_EXPIRES_IN=1d

# Mailtrap SMTP (used by the invoice email phase)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=
MAIL_FROM="Salon Booking System <no-reply@example.com>"
